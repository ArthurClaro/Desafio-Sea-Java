JWT_SECRET=troque-esta-chave-local-por-uma-chave-privada-com-32-caracteres-ou-mais
JWT_EXPIRATION_MS=3600000

# Frontend dev proxy (used by frontend/vite.config.js)
VITE_API_URL=http://localhost:8080
